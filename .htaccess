RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

ErrorDocument 404 /404.php

# ── Block direct HTTP access to sensitive files ────────────────────────────────
<FilesMatch "^(\.env|\.gitignore|composer\.json|composer\.lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>